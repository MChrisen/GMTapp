{
  "name": "gmt-exam-app",
  "private": true,
  "version": "0.1.0",
  "description": "GMT Eksamenhjælp — offline eksamensapp",
  "author": "GMT",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "predev": "npm run sync:pdfs",
    "sync:pdfs": "node scripts/sync-pdfs.mjs",
    "prebuild": "npm run sync:pdfs",
    "build": "tsc && vite build",
    "desktop": "electron .",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac dmg zip",
    "package:win": "npm run build && electron-builder --win portable nsis",
    "preview": "vite preview --host 127.0.0.1",
    "extract:pdfs": "python3 scripts/extract_pdfs.py",
    "refresh:pdfs": "npm run sync:pdfs && npm run extract:pdfs",
    "build:search-index": "python3 scripts/build_search_index.py",
    "validate:data": "node scripts/validate-data.mjs",
    "offline:smoke": "node scripts/offline-smoke.mjs",
    "qa": "npm run validate:data && npm run build && npm run offline:smoke"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "lucide-react": "latest",
    "pdfjs-dist": "^4.10.38",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "latest",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "typescript": "latest",
    "vite": "latest"
  },
  "build": {
    "appId": "dk.gmt.exam-helper",
    "productName": "GMT Eksamenhjælp",
    "copyright": "Copyright © 2026 GMT",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.education",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "artifactName": "GMT-Eksamenhjaelp-${os}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "GMT-Eksamenhjaelp-${os}-${arch}.${ext}"
    },
    "dmg": {
      "title": "GMT Eksamenhjælp"
    }
  }
}
